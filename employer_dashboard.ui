  <property name="styleSheet">
   <string notr="true">/* Genel Arka Plan ve Yazı */
QWidget {
    background-color: #f8fafc;
    font-family: 'Segoe UI', sans-serif;
    color: #1e293b;
}

/* Tablo Tasarımı */
QTableWidget {
    background-color: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    gridline-color: transparent; /* Izgara çizgilerini gizle */
}

QHeaderView::section {
    background-color: #f1f5f9;
    padding: 8px;
    border: none;
    border-bottom: 2px solid #e2e8f0;
    font-weight: bold;
    color: #64748b;
}

/* Butonlar */
#btn_add_job {
    background-color: #16a34a; /* Yeşil */
    color: white;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
}

#btn_accept {
    background-color: #2563eb; /* Mavi */
    color: white;
    border-radius: 6px;
    padding: 6px 14px;
}

#btn_reject {
    background-color: #dc2626; /* Kırmızı */
    color: white;
    border-radius: 6px;
    padding: 6px 14px;
}

/* Tab Sayfaları */
QTabWidget::pane {
    border: 1px solid #e2e8f0;
    background: white;
    border-radius: 8px;
}

QTabBar::tab {
    background: #f1f5f9;
    padding: 10px 20px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background: white;
    border-bottom: 2px solid #2563eb;
    font-weight: bold;
}</string>
