  <property name="styleSheet">
   <string notr="true">/* Genel Arka Plan */
QWidget {
    background-color: #f8fafc;
    font-family: 'Segoe UI', sans-serif;
}

/* Admin Paneli Başlığı */
#lbl_header {
    font-size: 22px;
    font-weight: 800;
    color: #0f172a;
    padding: 10px 0px;
    border-bottom: 2px solid #e2e8f0;
}

/* Tablolar */
QTableWidget {
    background-color: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    gridline-color: #f1f5f9;
}

QHeaderView::section {
    background-color: #f8fafc;
    padding: 8px;
    border: none;
    border-bottom: 1px solid #e2e8f0;
    font-weight: bold;
}

/* Kırmızı Silme Butonları */
#btn_delete_user, #btn_delete_job {
    background-color: #dc2626;
    color: white;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
}

#btn_delete_user:hover, #btn_delete_job:hover {
    background-color: #b91c1c;
}

/* Mavi Yenile Butonu */
#btn_refresh_report {
    background-color: #2563eb;
    color: white;
    border-radius: 6px;
    padding: 8px 20px;
}</string>
