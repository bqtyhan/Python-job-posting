  <property name="styleSheet">
   <string notr="true">/* Genel Ayarlar */
QWidget {
    background-color: #f8fafc;
    font-family: 'Segoe UI', sans-serif;
}

/* Giriş Alanları */
QLineEdit, QTextEdit, QComboBox {
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 6px;
    background-color: white;
}

QLineEdit:focus, QTextEdit:focus, QComboBox:focus {
    border: 2px solid #3b82f6; /* Odaklanınca mavi kenarlık */
}

/* Kaydet Butonu (Mavi) */
#btn_save {
    background-color: #2563eb;
    color: white;
    border-radius: 6px;
    padding: 8px 24px;
    font-weight: bold;
}

#btn_save:hover {
    background-color: #1d4ed8;
}

/* İptal Butonu (Gri/Beyaz) */
#btn_cancel {
    background-color: #f1f5f9;
    color: #475569;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 8px 20px;
}

#btn_cancel:hover {
    background-color: #e2e8f0;
}</string>
  </property>
