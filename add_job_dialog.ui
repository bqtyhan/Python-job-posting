       <property name="styleSheet">
        <string notr="true">#txt_description {
    background-color: white;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    /* Metnin kenarlara yapışmaması için ferah bir alan bırakıyoruz */
    padding: 8px 10px; 
    color: #1e293b;
    font-family: 'Segoe UI', sans-serif;
    font-size: 13px;
    /* Kutunun çok ezilmemesi için en az bir yükseklik veriyoruz */
    min-height: 100px; 
}

/* Kutuya tıklandığında (Odaklanınca) mavi çerçeve olsun */
#txt_description:focus {
    border: 2px solid #3b82f6;
    background-color: #ffffff;
}

/* Eğer placeholder rengi çok sönükse bunu ekleyebilirsin */
QPlainTextEdit {
    color: #1e293b;
}</string>
       </property>
