     <property name="styleSheet">
      <string notr="true">#JobCard { 
    background-color: white;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
}

#JobCard:hover {
    border-color: #2563eb;
}

/* Şirket, Konum ve Maaş etiketleri için modern kapsül stili */
#lbl_company, #lbl_location, #lbl_salary {
    background-color: #f8fafc; /* Çok açık gri arka plan */
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 4px 12px;
    color: #475569;
    font-size: 12px;
}

/* Etiketlerin üzerine gelince renk değişimi */
#lbl_company:hover, #lbl_location:hover, #lbl_salary:hover {
    background-color: #e2e8f0;
    color: #1e293b;
}

#lbl_title {
    font-size: 15px;
    font-weight: bold;
    color: #1e293b;
}</string>
